{
  "name": "playforge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "playwright test tests/unit --grep @unit",
    "test:ui": "playwright test tests/ui tests/unit --grep @ui",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "allure-commandline": "2.38.1",
    "allure-playwright": "3.7.1",
    "eslint": "10.2.0",
    "globals": "17.5.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "zod": "4.3.6"
  }
}
